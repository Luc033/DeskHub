# ===== PRODUÇÃO =====
# Copie este arquivo para .env e preencha os valores reais
# NUNCA commite o .env com secrets reais

# ===== SEGURANÇA =====
NODE_ENV=production
JWT_SECRET=GERE_UM_NOVO_SECRET_COM_openssl_rand_hex_32
REFRESH_SECRET=GERE_UM_NOVO_SECRET_COM_openssl_rand_hex_32
ENCRYPTION_KEY=GERE_UM_NOVO_SECRET_COM_openssl_rand_hex_32

# ===== BANCO DE DADOS =====
DB_USER=deskhub_user
DB_PASSWORD=GERE_UMA_SENHA_FORTE_AQUI
DB_NAME=deskhub_db
DB_HOST=postgres

# ===== API KEYS =====
GOOGLE_API_KEY=SUA_CHAVE_AQUI

# ===== URLS =====
PORT=3333
CORS_ORIGINS=https://seudominio.com.br
API_URL=https://seudominio.com.br

# ===== LOGS =====
LOG_LEVEL=warn
